generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  streak_count Int      @default(0)
  last_played  DateTime?
  total_points Int      @default(0)
}
